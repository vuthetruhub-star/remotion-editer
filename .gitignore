# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Root symlinks (local convenience only)
/motion-config.ts
/motion-scene.tsx

# Local AI tool settings/session — machine-specific. Track ONLY the shared skill.
.claude/*
!.claude/skills/

# Screenshots / preview images
*.png

# Large source/render videos (machine-specific, don't commit)
/public/*.mp4
/samples/*.mp4
/samples/*.webm

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
